{
  "name": "@coderpp/yunxiao-cli",
  "version": "0.1.9",
  "description": "A CLI for Yunxiao merge request, pipeline retry, project member, and workitem workflows.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderpp/yunxiao-cli.git"
  },
  "bugs": {
    "url": "https://github.com/coderpp/yunxiao-cli/issues"
  },
  "homepage": "https://github.com/coderpp/yunxiao-cli#readme",
  "bin": {
    "yunxiao": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "skills:sync": "scripts/sync-skills.sh",
    "skills:watch": "scripts/watch-skills.sh",
    "skills:watch:start": "scripts/start-skill-sync-watch.sh",
    "skills:watch:status": "scripts/status-skill-sync-watch.sh",
    "skills:watch:stop": "scripts/stop-skill-sync-watch.sh",
    "test": "tsc -p tsconfig.json && node --test dist/test/*.test.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.17"
  },
  "files": [
    "dist/src",
    "README.md"
  ]
}
